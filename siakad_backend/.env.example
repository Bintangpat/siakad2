# ===========================================
# DATABASE (PostgreSQL via Docker)
# ===========================================
POSTGRES_USER=siakad_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=siakad_db

DATABASE_URL="postgresql://siakad_user:your_db_password@localhost:5432/siakad_db?schema=public"

# ===========================================
# APPLICATION
# ===========================================
PORT=3000
NODE_ENV=development

# ===========================================
# JWT
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ===========================================
# PGADMIN (Development only)
# ===========================================
PGADMIN_EMAIL=admin@siakad.dev
PGADMIN_PASSWORD=your_pgadmin_password

# ===========================================
# CLOUDINARY (File Upload Lampiran Pengumuman)
# ===========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===========================================
# FIREBASE (Push Notification)
# ===========================================
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key\n-----END PRIVATE KEY-----\n"

# ===========================================
# PAYMENT GATEWAY (Placeholder)
# ===========================================
PAYMENT_GATEWAY_SECRET_KEY=your_payment_gateway_key
PAYMENT_GATEWAY_WEBHOOK_SECRET=your_webhook_secret
